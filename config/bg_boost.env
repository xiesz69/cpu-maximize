# Legacy single Discord webhook URL (optional)
DISCORD_WEBHOOK_URL=""

# Safety ceilings for total system usage
CPU_CEILING_PERCENT=85
RAM_CEILING_PERCENT=85

# Scan interval and crash detection
SCAN_INTERVAL_SEC=2
CRASH_GRACE_SEC=8

# Priority tuning
TARGET_NICE=-12
TARGET_OOM_FALLBACK=-700
NON_TARGET_NICE=8
NON_TARGET_OOM_ADJ=300

# Safeguard hysteresis
SAFEGUARD_RELEASE_STREAK=3

# Dashboard / Menu
DASHBOARD_REFRESH_SEC=1
NET_IFACE=""
MENU_PAGE_SIZE=20
STATUS_WARN_CPU=75
STATUS_WARN_RAM=75

# Logs
LOG_FILE="./logs/bg_boost.log"
